{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Auth": {
    "Jwt": {
      "Issuer": "EduHub",
      "Audience": "EduHub.Api",
      "AccessTokenMinutes": 15,
      "RefreshTokenDays": 7
    },
    "DevelopmentSeed": {
      "Enabled": false,
      "Email": "admin@eduhub.local",
      "Role": "SystemAdmin"
    }
  },
  "Grades": {
    "AutoLockAfterDays": 7
  },
  "Hangfire": {
    "DashboardEnabled": true
  },
  "Reports": {
    "StoragePath": ".local/reports"
  },
  "MinistryApi": {
    "BaseUrl": "https://localhost:9443",
    "ApiKey": "",
    "TimeoutSeconds": 10,
    "CircuitBreakerFailures": 5,
    "CircuitBreakerSeconds": 60
  },
  "Audit": {
    "Mongo": {
      "Enabled": true,
      "DatabaseName": "eduhub_audit",
      "CollectionName": "audit_logs",
      "RetentionDays": 90,
      "ServerSelectionTimeoutMilliseconds": 1000
    }
  }
}
