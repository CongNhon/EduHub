# Local-only defaults for a fresh clone. Do not reuse these credentials outside local development.
API_HOST_PORT=8080
ASPNETCORE_ENVIRONMENT=Development

Auth__Jwt__Issuer=EduHub
Auth__Jwt__Audience=EduHub.Api
Auth__Jwt__Secret=local-only-eduhub-jwt-signing-key-change-before-deployment-2026
Auth__Jwt__AccessTokenMinutes=15
Auth__Jwt__RefreshTokenDays=7

Auth__DevelopmentSeed__Enabled=false
Auth__DevelopmentSeed__Email=admin@eduhub.local
Auth__DevelopmentSeed__Password=Admin@123456
Auth__DevelopmentSeed__Role=SystemAdmin

POSTGRES_DB=eduhub
POSTGRES_USER=eduhub
POSTGRES_PASSWORD=eduhub_local_postgres
POSTGRES_HOST_PORT=5433
ConnectionStrings__Postgres=Host=localhost;Port=5433;Database=eduhub;Username=eduhub;Password=eduhub_local_postgres
DOCKER_POSTGRES_CONNECTION=Host=postgres;Port=5432;Database=eduhub;Username=eduhub;Password=eduhub_local_postgres

REDIS_PASSWORD=eduhub_local_redis
REDIS_HOST_PORT=6379
ConnectionStrings__Redis=localhost:6379,password=eduhub_local_redis

MONGO_INITDB_ROOT_USERNAME=eduhub
MONGO_INITDB_ROOT_PASSWORD=eduhub_local_mongo
MONGO_HOST_PORT=27018
ConnectionStrings__Mongo=mongodb://eduhub:eduhub_local_mongo@localhost:27018/?authSource=admin
DOCKER_MONGO_CONNECTION=mongodb://eduhub:eduhub_local_mongo@mongodb:27017/?authSource=admin

Hangfire__DashboardEnabled=true
Frontend__PortalBaseUrl=http://localhost:3001
Grades__AutoLockAfterDays=7
Reports__StoragePath=.local\reports

EvidenceStorage__R2__ServiceUrl=
EvidenceStorage__R2__AccessKey=
EvidenceStorage__R2__SecretKey=
EvidenceStorage__R2__BucketName=eduhub-profile-evidence
EvidenceStorage__LocalRootPath=.local\profile-evidence

MinistryApi__BaseUrl=https://localhost:9443
MinistryApi__ApiKey=
MinistryApi__TimeoutSeconds=10
MinistryApi__CircuitBreakerFailures=5
MinistryApi__CircuitBreakerSeconds=60

Audit__Mongo__Enabled=true
Audit__Mongo__DatabaseName=eduhub_audit
Audit__Mongo__CollectionName=audit_logs
Audit__Mongo__RetentionDays=90
Audit__Mongo__ServerSelectionTimeoutMilliseconds=1000

Email__Smtp__Enabled=false
Email__Smtp__Host=smtp.gmail.com
Email__Smtp__Port=587
Email__Smtp__SenderEmail=
Email__Smtp__SenderName=EduHub
Email__Smtp__Username=
Email__Smtp__Password=
