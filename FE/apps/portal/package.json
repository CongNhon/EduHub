{
  "name": "@eduhub/portal",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "devexpress:license": "devextreme-license --out app/devextreme-license.ts --force --no-gitignore",
    "devexpress:themes": "node scripts/sync-devexpress-themes.mjs",
    "predev": "devextreme-license --out app/devextreme-license.ts --force --no-gitignore && node scripts/sync-devexpress-themes.mjs",
    "dev": "next dev --port 3001",
    "prebuild": "devextreme-license --out app/devextreme-license.ts --force --no-gitignore && node scripts/sync-devexpress-themes.mjs",
    "build": "next build",
    "start": "next start --port 3001",
    "pretypecheck": "devextreme-license --out app/devextreme-license.ts --force --no-gitignore && node scripts/sync-devexpress-themes.mjs",
    "typecheck": "tsc --noEmit",
    "prelint": "devextreme-license --out app/devextreme-license.ts --force --no-gitignore && node scripts/sync-devexpress-themes.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@devexpress/analytics-core": "26.1.3",
    "@eduhub/api-client": "workspace:*",
    "@eduhub/auth": "workspace:*",
    "@eduhub/ui": "workspace:*",
    "@eduhub/validation": "workspace:*",
    "@hookform/resolvers": "5.4.0",
    "@microsoft/signalr": "10.0.0",
    "@tanstack/react-query": "5.101.2",
    "devexpress-dashboard": "26.1.3",
    "devexpress-dashboard-react": "26.1.3",
    "devexpress-reporting": "26.1.3",
    "devexpress-reporting-react": "26.1.3",
    "devexpress-richedit": "26.1.3",
    "devextreme": "26.1.3",
    "devextreme-react": "26.1.3",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "sonner": "2.0.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "26.1.1",
    "@types/prop-types": "15.7.13",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.19",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3"
  }
}
