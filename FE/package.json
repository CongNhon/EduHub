{
  "name": "eduhub-frontend",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev:site": "pnpm --filter @eduhub/site dev",
    "dev:portal": "pnpm --filter @eduhub/portal dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "api:generate": "openapi-typescript http://localhost:8080/swagger/v1/swagger.json -o packages/api-client/src/generated/schema.d.ts"
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0",
    "prettier": "3.9.5",
    "typescript": "5.9.3"
  }
}
